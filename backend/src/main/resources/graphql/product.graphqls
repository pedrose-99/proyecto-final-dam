extend type Query {
    allProducts(page: Int = 0, size: Int = 24): ProductPage
    productByEan(ean: String!): ProductDTO
    compareProduct(productId: ID!): ProductComparisonDTO
    optimizeBasket(productIds: [ID!]!): BasketOptimizationDTO
    productsByCategoryPaginated(categoryId: ID!, page: Int = 0, size: Int = 24): ProductPage
    productsByStore(storeId: ID!, page: Int = 0, size: Int = 24): ProductPage
    searchProducts(query: String!, page: Int = 0, size: Int = 10): ProductPage
    searchProductsByStore(query: String!, storeId: ID!, page: Int = 0, size: Int = 10): ProductPage
}

type ProductPage {
    content: [ProductDTO]
    totalElements: Int
    totalPages: Int
    number: Int
    size: Int
    first: Boolean
    last: Boolean
}

extend type Mutation {
    createProduct(name: String!, ean: String!, brand: String, categoryId: ID!): ProductDTO
    updateProduct(id: ID!, name: String, brand: String, image_url: String): ProductDTO
    deleteProduct(id: ID!): Boolean
}

type ProductDTO {
    productId: ID
    name: String
    brand: String
    ean: String
    description: String
    imageUrl: String
    quantity: Float
    unit: String
    categoryName: String
    categoryId: Int
    isFavorite: Boolean
    currentPrice: Float
}

# ─── Comparador ─────────────────────────────────────────

type ProductComparisonDTO {
    productId: ID
    name: String
    brand: String
    ean: String
    imageUrl: String
    description: String
    categoryName: String
    storePrices: [StorePriceDTO]
    bestPrice: StorePriceDTO
}

type StorePriceDTO {
    storeId: ID
    storeName: String
    storeLogo: String
    currentPrice: Float
    storeWebsite: String
    available: Boolean
    stock: Int
    url: String
    externaId: String
}

# ─── Optimización de Cesta ──────────────────────────────

type BasketOptimizationDTO {
    storeOptions: [StoreBasketDTO]
    cheapestStore: StoreBasketDTO
    totalProducts: Int
}

type StoreBasketDTO {
    storeId: ID
    storeName: String
    storeLogo: String
    totalCost: Float
    availableProducts: Int
    totalProducts: Int
    items: [BasketItemDTO]
}

type BasketItemDTO {
    productId: ID
    productName: String
    price: Float
    available: Boolean
}
