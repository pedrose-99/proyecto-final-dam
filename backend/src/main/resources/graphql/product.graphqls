extend type Query {
    allProducts: [ProductDTO]
    productByEan(ean: String!): ProductDTO
    productsByCategory(categoryId: ID!): [ProductDTO]
    compareProduct(productId: ID!): ProductComparisonDTO
    optimizeBasket(productIds: [ID!]!): BasketOptimizationDTO
}

extend type Mutation {
    createProduct(name: String!, ean: String!, brand: String, categoryId: ID!): ProductDTO
    updateProduct(id: ID!, name: String, brand: String, image_url: String): ProductDTO
    deleteProduct(id: ID!): Boolean
}

type ProductDTO {
    productId: ID
    name: String
    brand: String
    ean: String
    description: String
    imageUrl: String
    quantity: Float
    unit: String
    categoryName: String
    categoryId: Int
}

# ─── Comparador ─────────────────────────────────────────

type ProductComparisonDTO {
    productId: ID
    name: String
    brand: String
    ean: String
    imageUrl: String
    categoryName: String
    storePrices: [StorePriceDTO]
    bestPrice: StorePriceDTO
}

type StorePriceDTO {
    storeId: ID
    storeName: String
    storeLogo: String
    currentPrice: Float
    available: Boolean
    stock: Int
    url: String
}

# ─── Optimización de Cesta ──────────────────────────────

type BasketOptimizationDTO {
    storeOptions: [StoreBasketDTO]
    cheapestStore: StoreBasketDTO
    totalProducts: Int
}

type StoreBasketDTO {
    storeId: ID
    storeName: String
    storeLogo: String
    totalCost: Float
    availableProducts: Int
    totalProducts: Int
    items: [BasketItemDTO]
}

type BasketItemDTO {
    productId: ID
    productName: String
    price: Float
    available: Boolean
}
